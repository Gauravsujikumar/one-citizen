{
  "version": 2,
  "builds": [
    {
      "src": "backend/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "officer_portal/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/backend/server.js" },
    { "src": "/uploads/(.*)", "dest": "/backend/server.js" },
    { "src": "/(.*\\.(js|css|png|jpg|jpeg|gif|svg|ico|webp|woff|woff2|ttf))", "dest": "/officer_portal/$1" },
    { "src": "/(.*)", "dest": "/officer_portal/index.html" }
  ]
}
